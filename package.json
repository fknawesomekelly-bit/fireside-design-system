{
  "name": "fireside-design-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev:storybook": "pnpm --filter @fireside/docs storybook",
    "dev:playground": "pnpm --filter playground dev",
    "test": "pnpm -r --if-present test",
    "validate": "node scripts/validate-all.mjs",
    "validate:tokens": "node scripts/validators/check-tokens.mjs",
    "validate:components": "node scripts/validators/check-components.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "husky": "^9.1.6",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0"
  }
}
